# Memory Database API (required for non-dry-run syncs)
MEMORY_DATABASE_API_URL=http://localhost:3000
MEMORY_DATABASE_API_WRITE_TOKEN=

# Human display name used for user messages
SENDER_NAME=ET

# Optional source roots (defaults shown)
CLAUDE_DATA_DIR=~/.claude
CODEX_DATA_DIR=~/.codex
OPENCODE_DATA_DIR=~/.local/share/opencode
ANTIGRAVITY_DATA_DIR=~/.gemini/antigravity-cli
PI_DATA_DIR=~/.pi/agent

# Service settings
PORT=3460
HOST=0.0.0.0
AUTO_SYNC=false
SYNC_INTERVAL_MS=900000
WRITE_CONCURRENCY=2
API_TIMEOUT_MS=30000
DATA_DIR=.data

# Optional Bearer token for POST /api/sync
INGESTOR_API_TOKEN=
